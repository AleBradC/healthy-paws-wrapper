# =====================================================================
# Healthy Paws — Wrapper environment template
# =====================================================================
# Copy this file to `.env` in the same directory (healthy-paws-wrapper/.env)
# and fill in real values. docker-compose reads this `.env` for ${...}
# interpolation in docker-compose.yml.
#
# Values here MUST match the same names in healthy-paws-service/.env or
# the `db` and `backend` services will disagree.

# --- Postgres ---------------------------------------------------------
DB_USER=healthy_paws
DB_PASSWORD=change-me-strong-password
DB_DATABASE=healthy_paws
